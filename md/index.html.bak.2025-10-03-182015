  <style>
    .sidebar-transition { transition: transform 200ms ease, width 200ms ease; }
    body.sidebar-open { overflow: hidden; }

    /* Sidebar sizing */
    #sidebar.expanded { width: 10rem; /* w-40 ~ 160px */ }
    #sidebar.collapsed { width: 4rem;  /* w-16 ~ 64px  */ }

    /* Keep icon + label in one line; hide labels when collapsed */
    .navlink { display:flex; align-items:center; gap:.625rem; white-space:nowrap; }
    #sidebar.collapsed .navlink .label { display:none; }
    .navicon { display:block; width:18px; height:18px; flex:0 0 18px; }

    /* Make list bullets never appear */
    #sidebar ul { list-style: none; padding-left: 0; margin: 0; }

    /* Mobile behavior: convert collapsed rail to slide-out */
    @media (max-width: 768px) {
      #sidebar { position: fixed; inset: calc(3.25rem) auto 0 0; z-index: 40; }
      /* When hidden on mobile, slide off-canvas */
      #sidebar.hidden-mobile { transform: translateX(-100%); }
      /* When shown on mobile, use expanded width */
      #sidebar.expanded { width: 12rem; } /* a bit wider on phones */
    }
  </style>
