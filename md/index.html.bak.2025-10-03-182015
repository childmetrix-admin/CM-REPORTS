  <!-- Behavior -->
  <script>
    // --- Sidebar expand/collapse with chevron + tooltips ---
    (function() {
      const sidebar = document.getElementById('sidebar');
      const toggle  = document.getElementById('sidebarToggle');
      const chevL   = document.getElementById('chevLeft');
      const chevR   = document.getElementById('chevRight');
      const KEY     = 'cm.sidebar.state'; // 'expanded' | 'collapsed'
      const COLLAPSE_AT = 1100; // px: auto-collapse threshold

      function setState(state, {persist=true} = {}) {
        sidebar.classList.remove('expanded','collapsed','hidden-mobile');
        if (window.innerWidth <= 768 && state === 'collapsed') {
          // on phones: keep a slide-out model only when user asks to show
          sidebar.classList.add('expanded','hidden-mobile'); // hidden by default
        } else {
          sidebar.classList.add(state);
        }
        // icon + labels
        const isCollapsed = state === 'collapsed' || sidebar.classList.contains('hidden-mobile');
        chevL.classList.toggle('hidden', isCollapsed);
        chevR.classList.toggle('hidden', !isCollapsed);
        toggle.setAttribute('aria-label', isCollapsed ? 'Show menu' : 'Hide menu');
        toggle.setAttribute('title',      isCollapsed ? 'Show menu' : 'Hide menu');
        if (persist) try { localStorage.setItem(KEY, state); } catch(e) {}
      }

      function initialState() {
        let saved = null;
        try { saved = localStorage.getItem(KEY); } catch(e) {}
        if (window.innerWidth < COLLAPSE_AT) {
          setState('collapsed', {persist:false});
        } else {
          setState(saved === 'collapsed' ? 'collapsed' : 'expanded', {persist:false});
        }
      }

      // Toggle click
      toggle.addEventListener('click', () => {
        // Mobile special case: if hidden off-canvas, show it temporarily
        if (window.innerWidth <= 768) {
          const hidden = sidebar.classList.contains('hidden-mobile');
          if (hidden) {
            sidebar.classList.remove('hidden-mobile');
            // While visible, treat as expanded
            chevL.classList.add('hidden');  chevR.classList.remove('hidden');
            toggle.setAttribute('aria-label','Hide menu');
            toggle.setAttribute('title','Hide menu');
          } else {
            sidebar.classList.add('hidden-mobile');
            chevL.classList.remove('hidden'); chevR.classList.add('hidden');
            toggle.setAttribute('aria-label','Show menu');
            toggle.setAttribute('title','Show menu');
          }
          return;
        }
        const isCollapsed = sidebar.classList.contains('collapsed');
        setState(isCollapsed ? 'expanded' : 'collapsed');
      });

      // Close slide-out if user taps outside on mobile
      document.addEventListener('click', (e) => {
        if (window.innerWidth > 768) return;
        if (sidebar.contains(e.target) || toggle.contains(e.target)) return;
        if (!sidebar.classList.contains('hidden-mobile')) {
          sidebar.classList.add('hidden-mobile');
          chevL.classList.remove('hidden'); chevR.classList.add('hidden');
          toggle.setAttribute('aria-label','Show menu');
          toggle.setAttribute('title','Show menu');
        }
      });

      // Respond to resizes
      window.addEventListener('resize', () => {
        if (window.innerWidth < COLLAPSE_AT) {
          setState('collapsed', {persist:false});
        } else {
          // restore saved preference
          let saved = null;
          try { saved = localStorage.getItem(KEY); } catch(e) {}
          setState(saved === 'collapsed' ? 'collapsed' : 'expanded', {persist:false});
        }
      });

      initialState();
    })();

    // --- Router + active highlight + querystring filters ---
    (function() {
      const navList      = document.getElementById('navList');
      const frame        = document.getElementById('reportFrame');
      const filterPeriod = document.getElementById('filterPeriod');
      const filterGeo    = document.getElementById('filterGeo');

      function setActive(hash) {
        navList.querySelectorAll('a').forEach(a => {
          const active = a.getAttribute('href') === hash;
          a.classList.toggle('bg-white', active);
          a.classList.toggle('font-semibold', active);
          a.classList.toggle('text-cm.primary', active);
        });
      }

      function navigate() {
        const hash = location.hash || '#/in-home';
        setActive(hash);
        const a = navList.querySelector(`a[href="${hash}"]`);
        if (!a || !frame) return;

        const base = a.dataset.target || '/md/in_home/current/index.html';
        const qp = new URLSearchParams({
          period: filterPeriod ? filterPeriod.value : 'current',
          geo:    filterGeo ? filterGeo.value : 'state'
        });
        frame.src = `${base}?${qp.toString()}`;
      }

      window.addEventListener('hashchange', navigate);
      filterPeriod?.addEventListener('change', navigate);
      filterGeo?.addEventListener('change', navigate);
      navigate();
    })();

    // --- Auto-resize iframe to embedded report height (same-origin) ---
    (function() {
      const frame = document.getElementById('reportFrame');
      function tryResize() {
        if (!frame) return;
        try {
          const doc = frame.contentDocument || frame.contentWindow.document;
          if (!doc) return;
          const h = Math.max(
            doc.body.scrollHeight, doc.documentElement.scrollHeight,
            doc.body.offsetHeight, doc.documentElement.offsetHeight,
            doc.body.clientHeight, doc.documentElement.clientHeight
          );
          frame.style.height = h + 'px';
        } catch(e) { /* cross-origin ignore */ }
      }
      frame?.addEventListener('load', tryResize);
      setInterval(tryResize, 1000);
    })();
  </script>
