# Text files → normalize to LF in repo; Windows will still check out CRLF if core.autocrlf is true
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.md   text eol=lf

# Images/binaries
*.pptx binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
# SVG files are often text; keep LF
*.svg  text eol=lf

# Backups not tracked as special, but if they slip in, treat as text
*.bak   text eol=lf
*.save  text eol=lf
