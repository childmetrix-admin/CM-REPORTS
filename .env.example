# ChildMetrix Reports - Environment Configuration
# Copy to .env and fill in values

# === Azure Authentication (Entra External ID) ===
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_AUTHORITY=https://login.microsoftonline.com/<tenant-id>

# === Azure Storage (Blob) — required for CFSR extraction and Shiny apps ===
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_ENDPOINT=https://<account>.blob.core.windows.net
AZURE_BLOB_CONTAINER_RAW=raw
AZURE_BLOB_CONTAINER_PROCESSED=processed

# === Azure SQL Database ===
AZURE_SQL_SERVER=<server>.database.windows.net
AZURE_SQL_DATABASE=
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=

# === Azure Container Registry ===
AZURE_ACR_LOGIN_SERVER=<registry>.azurecr.io
AZURE_ACR_USERNAME=
AZURE_ACR_PASSWORD=

# === Application Settings ===
CM_ENVIRONMENT=dev
CM_REPORTS_ROOT=

# Public HTTPS bases for slide placeholders / links (PowerPoint, docs). Override per environment.
CM_PUBLIC_SUMMARY_URL=https://ca-app-summary.icyforest-fe9bbf66.southcentralus.azurecontainerapps.io
CM_PUBLIC_MEASURES_URL=https://ca-app-measures.icyforest-fe9bbf66.southcentralus.azurecontainerapps.io

# CFSR PowerPoint generation (domains/cfsr/scripts/generate_ppt.R, functions_cfsr_profile_ppt.R)
# CFSR_PPT_USE_LOCAL_RDS=1 — read RDS from domains/cfsr/data/rds/ instead of Azure (skips blob paths init).
# AUTO_CAPTURE=1 — when set, Rscript generate_ppt.R runs webshot2 screenshots first (requires Chrome/Chromium).
# CFSR_PATHS_ALLOW_NO_AZURE=1 — allow sourcing paths.R without AZURE_BLOB_ENDPOINT (path-string helpers only).

# Container image runtimes map host ports to these internally (see infrastructure/docker/shiny/*/Dockerfile)
CM_SHINY_MEASURES_PORT=3838
CM_SHINY_SUMMARY_PORT=3840
