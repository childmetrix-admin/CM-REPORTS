# ChildMetrix Reports - Environment Configuration
# Copy to .env and fill in values

# === Azure Authentication (Entra External ID) ===
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_AUTHORITY=https://login.microsoftonline.com/<tenant-id>

# === Azure Storage (Blob) ===
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_ENDPOINT=https://<account>.blob.core.windows.net
AZURE_BLOB_CONTAINER_RAW=raw
AZURE_BLOB_CONTAINER_PROCESSED=processed

# === Azure SQL Database ===
AZURE_SQL_SERVER=<server>.database.windows.net
AZURE_SQL_DATABASE=
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=

# === Azure Container Registry ===
AZURE_ACR_LOGIN_SERVER=<registry>.azurecr.io
AZURE_ACR_USERNAME=
AZURE_ACR_PASSWORD=

# === Application Settings ===
CM_ENVIRONMENT=dev
CM_DATA_SOURCE=sharefile
CM_REPORTS_ROOT=
CM_SHINY_BASE_URL=http://localhost

# Public HTTPS bases for slide placeholders / links (PowerPoint, docs). Override for non-Azure envs.
CM_PUBLIC_SUMMARY_URL=https://ca-app-summary.icyforest-fe9bbf66.southcentralus.azurecontainerapps.io
CM_PUBLIC_MEASURES_URL=https://ca-app-measures.icyforest-fe9bbf66.southcentralus.azurecontainerapps.io

# === Shiny App Ports (local development) ===
CM_SHINY_MEASURES_PORT=3838
CM_SHINY_SUMMARY_PORT=3840

# === ShareFile (legacy, used when CM_DATA_SOURCE=sharefile) ===
SHAREFILE_BASE=S:/Shared Folders
