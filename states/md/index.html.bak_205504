<!doctype html>
<html lang="en" class="h-full">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>ChildMetrix — Maryland (Staging)</title>

  <!-- Tailwind (use your deployed Tailwind or swap CDN) -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Optional: brand palette -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            cm: {
              primary: '#1C7ED6',
              primaryDark: '#1864AB',
              accent: '#82C91E',
              gray: '#EEF2F6',
              darkBlue: '#4472C4',
              lightBlue: '#52C8FA'
            }
          }
        }
      }
    }
  </script>

  <style>
    .sidebar-transition { transition: transform 200ms ease, width 200ms ease; }
    body.sidebar-open { overflow: hidden; }

    /* Sidebar sizing */
    #sidebar.expanded { width: 10rem; /* w-40 ~ 160px */ }
    #sidebar.collapsed { width: 4rem;  /* w-16 ~ 64px  */ }

    /* Keep icon + label in one line; hide labels when collapsed */
    .navlink { display:flex; align-items:center; gap:.625rem; white-space:nowrap; }
    #sidebar.collapsed .navlink .label { display:none; }
    .navicon { display:block; width:18px; height:18px; flex:0 0 18px; }

    /* Make list bullets never appear */
    #sidebar ul { list-style: none; padding-left: 0; margin: 0; }

    /* Mobile behavior: convert collapsed rail to slide-out */
    @media (max-width: 768px) {
      #sidebar { position: fixed; inset: calc(3.25rem) auto 0 0; z-index: 40; }
      /* When hidden on mobile, slide off-canvas */
      #sidebar.hidden-mobile { transform: translateX(-100%); }
      /* When shown on mobile, use expanded width */
      #sidebar.expanded { width: 12rem; } /* a bit wider on phones */
    }
  </style>
</head>
<body class="h-full bg-white text-slate-800">

  <div class="min-h-screen flex flex-col">

    <!-- Header -->
    <header class="flex items-center justify-between px-4 md:px-6 py-3 border-b bg-white">
      <div class="flex items-center gap-3">
        <!-- Sidebar toggle (chevron) -->
        <button id="sidebarToggle"
                class="inline-flex items-center justify-center border px-2 py-1 text-sm"
                aria-label="Hide menu" title="Hide menu">
          <!-- left chevron (expanded) / right chevron (collapsed); JS swaps them -->
          <svg id="chevLeft"  xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 6l-6 6 6 6"/></svg>
          <svg id="chevRight" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg>
        </button>

        <!-- Branding -->
        <div class="flex items-center gap-3">
          <img src="../_assets/logo.png" alt="ChildMetrix" class="h-8 w-auto" />
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium px-2 py-0.5 bg-cm.gray">Maryland</span>
            <span class="text-xs font-medium px-2 py-0.5 bg-yellow-100 text-yellow-800 border border-yellow-200">Staging</span>
          </div>
        </div>
      </div>

      <!-- Utility links -->
      <div class="flex items-center gap-2">
        <a href="#/help" class="inline-flex items-center gap-2 px-3 py-1.5 text-sm hover:bg-slate-50 rounded">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M9.5 9a2.5 2.5 0 114.1 1.9c-.7.5-1.1 1-1.1 1.6V14"></path>
            <circle cx="12" cy="17" r="0.8"></circle>
          </svg>
          <span>Help</span>
        </a>
        <a href="#/settings" class="inline-flex items-center gap-2 px-3 py-1.5 text-sm hover:bg-slate-50 rounded">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 15.5a3.5 3.5 0 100-7 3.5 3.5 0 000 7z"></path>
            <path d="M19.4 15a1.7 1.7 0 00.3 1.8l.1.1a2 2 0 01-2.8 2.8l-.1-.1a1.7 1.7 0 00-1.8-.3 1.7 1.7 0 00-1 1.6V22a2 2 0 01-4 0v-.1a1.7 1.7 0 00-1-1.6 1.7 1.7 0 00-1.8.3l-.1.1A2 2 0 013.1 17l.1-.1a1.7 1.7 0 00.3-1.8 1.7 1.7 0 00-1.6-1H1.9a2 2 0 010-4h.1a1.7 1.7 0 001.6-1 1.7 1.7 0 00-.3-1.8l-.1-.1A2 2 0 014.7 3.7l.1.1a1.7 1.7 0 001.8.3 1.7 1.7 0 001-1.6V2a2 2 0 014 0v.1a1.7 1.7 0 001 1.6 1.7 1.7 0 001.8-.3l.1-.1a2 2 0 012.8 2.8l-.1.1a1.7 1.7 0 00-.3 1.8 1.7 1.7 0 001.6 1h.1a2 2 0 010 4h-.1a1.7 1.7 0 00-1.6 1z"></path>
          </svg>
          <span>Settings</span>
        </a>
        <a href="/" class="inline-flex items-center gap-2 px-3 py-1.5 text-sm hover:bg-slate-50 rounded">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h3a2 2 0 012 2v14a2 2 0 01-2 2h-3"></path>
            <path d="M10 17l5-5-5-5"></path>
            <path d="M15 12H3"></path>
          </svg>
          <span>Sign out</span>
        </a>
      </div>
    </header>

    <!-- Main layout -->
    <div class="flex flex-1 overflow-hidden min-h-0">

      <!-- Sidebar rail (icons always visible; labels hide on collapse) -->
      <aside id="sidebar" class="sidebar-transition bg-slate-50 border-r expanded flex flex-col" style="height: calc(100vh - 3.25rem);" aria-label="Primary">
        <!-- Primary links -->
        <nav class="flex-1 overflow-y-auto">
          <div class="px-2 py-4">
            <ul id="navList" class="space-y-0.5 text-sm">
              <li>
                <a href="#/home" data-target="home/index.html" class="px-2 py-2 hover:bg-white navlink">
                  <!-- home -->
                  <svg class="navicon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 10.5 12 3l9 7.5"></path><path d="M5 9.5V21h14V9.5"></path><path d="M9 21v-6h6v6"></path>
                  </svg>
                  <span class="label">Home</span>
                </a>
              </li>
              <li>
                <a href="#/cps" data-target="cps/current/index.html" class="px-2 py-2 hover:bg-white navlink">
                  <!-- shield-check -->
                  <svg class="navicon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 3l7 4v5c0 5-3.5 7.5-7 9-3.5-1.5-7-4-7-9V7l7-4z"></path>
                    <path d="M9.5 12l1.8 1.8L14.5 10"></path>
                  </svg>
                  <span class="label">CPS</span>
                </a>
              </li>
              <li>
                <a href="#/in-home" data-target="in_home/current/index.html" class="px-2 py-2 hover:bg-white navlink">
                  <!-- users -->
                  <svg class="navicon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M16 11a4 4 0 10-8 0"></path>
                    <path d="M3 21a7 7 0 0118 0"></path>
                  </svg>
                  <span class="label">In-Home</span>
                </a>
              </li>
              <li>
                <a href="#/ooh" data-target="ooh/current/index.html" class="px-2 py-2 hover:bg-white navlink">
                  <!-- home-user -->
                  <svg class="navicon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 10.5 12 3l9 7.5"></path><path d="M5 9.5V21h14V9.5"></path>
                    <circle cx="12" cy="14" r="2"></circle><path d="M8.5 20a5.5 5.5 0 017 0"></path>
                  </svg>
                  <span class="label">Out of Home</span>
                </a>
              </li>
              <li>
                <a href="#/cfsr" data-target="cfsr/performance/index_auto.html" class="px-2 py-2 hover:bg-white navlink">
                  <!-- checklist -->
                  <svg class="navicon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M9 7h9"></path><path d="M9 12h9"></path><path d="M9 17h9"></path>
                    <path d="M5 7h.01"></path><path d="M5 12h.01"></path><path d="M5 17h.01"></path>
                  </svg>
                  <span class="label">CFSR Data Profile</span>
                </a>
              </li>
            </ul>
          </div>
        </nav>
      </aside>

      <!-- Content -->
      <main class="flex-1 overflow-hidden flex flex-col">
        <!-- Secondary menu bar -->
        <nav class="flex items-center justify-between px-4 py-2 border-b bg-white">
          <div class="flex items-center gap-1">
            <a href="#" id="secondaryPerformance" class="px-3 py-1.5 text-sm hover:bg-slate-50 rounded">Performance</a>
            <a href="#" id="secondaryPresentations" class="px-3 py-1.5 text-sm hover:bg-slate-50 rounded">Presentations</a>
            <a href="#" id="secondaryDataDict" class="px-3 py-1.5 text-sm hover:bg-slate-50 rounded">Data Dictionary</a>
            <a href="#" id="secondaryNotes" class="px-3 py-1.5 text-sm hover:bg-slate-50 rounded">Notes</a>
          </div>

          <!-- Period selector (shown only for Performance) -->
          <div id="periodSelector" style="display: none;">
            <label class="text-sm inline-flex items-center gap-2">
              <span>CFSR Profile Period:</span>
              <select id="cfsrPeriodSelect" class="border px-2 py-1 text-sm rounded">
                <option value="2025_02" selected>February 2025</option>
                <option value="2024_08">August 2024</option>
                <option value="2024_02">February 2024</option>
              </select>
            </label>
          </div>
        </nav>

        <!-- CFSR Tertiary navigation (shown only when CFSR Performance is active) -->
        <nav id="cfsrTertiaryNav" class="flex items-center px-4 py-2 border-b bg-slate-50" style="display: none;">
          <div class="flex items-center gap-1">
            <a href="#" id="tertiaryStateVsNational" class="px-3 py-1.5 text-sm hover:bg-white rounded">State Performance vs. National Standards</a>
            <a href="#" id="tertiaryStateByState" class="px-3 py-1.5 text-sm hover:bg-white rounded bg-white font-semibold">State-by-State Performance</a>
            <a href="#" id="tertiaryCountyByCounty" class="px-3 py-1.5 text-sm hover:bg-white rounded">County-by-County Performance</a>
          </div>
        </nav>

        <div class="flex-1 overflow-hidden">
          <iframe id="reportFrame"
                  title="Report"
                  src="home/index.html"
                  class="w-full h-full border-0"></iframe>
        </div>
      </main>
    </div>
  </div>

  <!-- Behavior -->
  <script>
    // --- Sidebar expand/collapse with chevron + tooltips ---
    (function() {
      const sidebar = document.getElementById('sidebar');
      const toggle  = document.getElementById('sidebarToggle');
      const chevL   = document.getElementById('chevLeft');
      const chevR   = document.getElementById('chevRight');
      const KEY     = 'cm.sidebar.state'; // 'expanded' | 'collapsed'
      const COLLAPSE_AT = 1100; // px: auto-collapse threshold

      function setState(state, {persist=true} = {}) {
        sidebar.classList.remove('expanded','collapsed','hidden-mobile');
        if (window.innerWidth <= 768 && state === 'collapsed') {
          // on phones: keep a slide-out model only when user asks to show
          sidebar.classList.add('expanded','hidden-mobile'); // hidden by default
        } else {
          sidebar.classList.add(state);
        }
        // icon + labels
        const isCollapsed = state === 'collapsed' || sidebar.classList.contains('hidden-mobile');
        chevL.classList.toggle('hidden', isCollapsed);
        chevR.classList.toggle('hidden', !isCollapsed);
        toggle.setAttribute('aria-label', isCollapsed ? 'Show menu' : 'Hide menu');
        toggle.setAttribute('title',      isCollapsed ? 'Show menu' : 'Hide menu');
        if (persist) try { localStorage.setItem(KEY, state); } catch(e) {}
      }

      function initialState() {
        let saved = null;
        try { saved = localStorage.getItem(KEY); } catch(e) {}
        if (window.innerWidth < COLLAPSE_AT) {
          setState('collapsed', {persist:false});
        } else {
          setState(saved === 'collapsed' ? 'collapsed' : 'expanded', {persist:false});
        }
      }

      // Toggle click
      toggle.addEventListener('click', () => {
        // Mobile special case: if hidden off-canvas, show it temporarily
        if (window.innerWidth <= 768) {
          const hidden = sidebar.classList.contains('hidden-mobile');
          if (hidden) {
            sidebar.classList.remove('hidden-mobile');
            // While visible, treat as expanded
            chevL.classList.add('hidden');  chevR.classList.remove('hidden');
            toggle.setAttribute('aria-label','Hide menu');
            toggle.setAttribute('title','Hide menu');
          } else {
            sidebar.classList.add('hidden-mobile');
            chevL.classList.remove('hidden'); chevR.classList.add('hidden');
            toggle.setAttribute('aria-label','Show menu');
            toggle.setAttribute('title','Show menu');
          }
          return;
        }
        const isCollapsed = sidebar.classList.contains('collapsed');
        setState(isCollapsed ? 'expanded' : 'collapsed');
      });

      // Close slide-out if user taps outside on mobile
      document.addEventListener('click', (e) => {
        if (window.innerWidth > 768) return;
        if (sidebar.contains(e.target) || toggle.contains(e.target)) return;
        if (!sidebar.classList.contains('hidden-mobile')) {
          sidebar.classList.add('hidden-mobile');
          chevL.classList.remove('hidden'); chevR.classList.add('hidden');
          toggle.setAttribute('aria-label','Show menu');
          toggle.setAttribute('title','Show menu');
        }
      });

      // Respond to resizes
      window.addEventListener('resize', () => {
        if (window.innerWidth < COLLAPSE_AT) {
          setState('collapsed', {persist:false});
        } else {
          // restore saved preference
          let saved = null;
          try { saved = localStorage.getItem(KEY); } catch(e) {}
          setState(saved === 'collapsed' ? 'collapsed' : 'expanded', {persist:false});
        }
      });

      initialState();
    })();

    // --- Router + active highlight + secondary menu navigation ---
    (function() {
      const navList = document.getElementById('navList');
      const frame   = document.getElementById('reportFrame');
      const periodSelector = document.getElementById('periodSelector');
      const periodSelect = document.getElementById('cfsrPeriodSelect');
      const secondaryPerformance = document.getElementById('secondaryPerformance');
      const secondaryPresentations = document.getElementById('secondaryPresentations');
      const secondaryDataDict = document.getElementById('secondaryDataDict');
      const secondaryNotes = document.getElementById('secondaryNotes');
      const cfsrTertiaryNav = document.getElementById('cfsrTertiaryNav');
      const tertiaryStateVsNational = document.getElementById('tertiaryStateVsNational');
      const tertiaryStateByState = document.getElementById('tertiaryStateByState');
      const tertiaryCountyByCounty = document.getElementById('tertiaryCountyByCounty');

      let currentCategory = null; // Track current report category (cfsr, cps, etc.)
      let currentSubsection = 'performance'; // Track subsection within CFSR
      let currentTertiary = 'state_by_state'; // Track tertiary selection within CFSR Performance

      function setActive(hash) {
        navList.querySelectorAll('a').forEach(a => {
          const active = a.getAttribute('href') === hash;
          a.classList.toggle('bg-white', active);
          a.classList.toggle('font-semibold', active);
          a.classList.toggle('text-cm.primary', active);
        });
      }

      function setSecondaryActive(subsection) {
        [secondaryPerformance, secondaryPresentations, secondaryDataDict, secondaryNotes].forEach(a => {
          a.classList.remove('bg-slate-100', 'font-semibold');
        });

        if (subsection === 'performance') secondaryPerformance.classList.add('bg-slate-100', 'font-semibold');
        if (subsection === 'presentations') secondaryPresentations.classList.add('bg-slate-100', 'font-semibold');
        if (subsection === 'data_dictionary') secondaryDataDict.classList.add('bg-slate-100', 'font-semibold');
        if (subsection === 'notes') secondaryNotes.classList.add('bg-slate-100', 'font-semibold');
      }

      function setTertiaryActive(tertiary) {
        [tertiaryStateVsNational, tertiaryStateByState, tertiaryCountyByCounty].forEach(a => {
          a.classList.remove('bg-white', 'font-semibold');
        });

        if (tertiary === 'state_vs_national') tertiaryStateVsNational.classList.add('bg-white', 'font-semibold');
        if (tertiary === 'state_by_state') tertiaryStateByState.classList.add('bg-white', 'font-semibold');
        if (tertiary === 'county_by_county') tertiaryCountyByCounty.classList.add('bg-white', 'font-semibold');
      }

      function navigate() {
        const hash = location.hash || '#/home';
        setActive(hash);
        const a = navList.querySelector(`a[href="${hash}"]`);
        if (!a || !frame) return;

        // Determine current category
        currentCategory = hash.replace('#/', '');

        // Show/hide period selector and tertiary nav based on category and subsection
        if (currentCategory === 'cfsr' && currentSubsection === 'performance') {
          periodSelector.style.display = 'block';
          cfsrTertiaryNav.style.display = 'flex';
          setTertiaryActive(currentTertiary);
        } else {
          periodSelector.style.display = 'none';
          cfsrTertiaryNav.style.display = 'none';
        }

        const base = a.dataset.target || 'in_home/current/index.html';
        frame.src = base;

        // Update secondary menu active state
        if (currentCategory === 'cfsr') {
          setSecondaryActive(currentSubsection);
        }
      }

      // Secondary menu navigation
      secondaryPerformance.addEventListener('click', (e) => {
        e.preventDefault();
        if (currentCategory === 'cfsr') {
          currentSubsection = 'performance';
          currentTertiary = 'state_by_state';
          const period = periodSelect.value;
          frame.src = `cfsr/performance/index_auto.html?profile=${period}`;
          periodSelector.style.display = 'block';
          cfsrTertiaryNav.style.display = 'flex';
          setSecondaryActive('performance');
          setTertiaryActive(currentTertiary);
        }
      });

      secondaryPresentations.addEventListener('click', (e) => {
        e.preventDefault();
        if (currentCategory === 'cfsr') {
          currentSubsection = 'presentations';
          frame.src = 'cfsr/presentations/index.html';
          periodSelector.style.display = 'none';
		  cfsrTertiaryNav.style.display = 'none';
          setSecondaryActive('presentations');
        }
      });

      secondaryDataDict.addEventListener('click', (e) => {
        e.preventDefault();
        if (currentCategory === 'cfsr') {
          currentSubsection = 'data_dictionary';
          frame.src = 'cfsr/data_dictionary/index.html';
          periodSelector.style.display = 'none';
		  cfsrTertiaryNav.style.display = 'none';
          setSecondaryActive('data_dictionary');
        }
      });

      secondaryNotes.addEventListener('click', (e) => {
        e.preventDefault();
        if (currentCategory === 'cfsr') {
          currentSubsection = 'notes';
          frame.src = 'cfsr/notes/index.html';
          periodSelector.style.display = 'none';
		  cfsrTertiaryNav.style.display = 'none';
          setSecondaryActive('notes');
        }
      });

      // Period selector change
      periodSelect.addEventListener('change', () => {
        const period = periodSelect.value;
        // Update the Shiny dashboard with new profile parameter
        frame.src = `cfsr/performance/index_auto.html?profile=${period}`;
      });
	  
	  // Tertiary navigation click handlers
      tertiaryStateVsNational.addEventListener('click', (e) => {
        e.preventDefault();
        if (currentCategory === 'cfsr' && currentSubsection === 'performance') {
          currentTertiary = 'state_vs_national';
          setTertiaryActive(currentTertiary);
          frame.src = 'cfsr/performance/state_vs_national.html';
        }
      });

      tertiaryStateByState.addEventListener('click', (e) => {
        e.preventDefault();
        if (currentCategory === 'cfsr' && currentSubsection === 'performance') {
          currentTertiary = 'state_by_state';
          setTertiaryActive(currentTertiary);
          const period = periodSelect.value;
          frame.src = `cfsr/performance/index_auto.html?profile=${period}`;
        }
      });

      tertiaryCountyByCounty.addEventListener('click', (e) => {
        e.preventDefault();
        if (currentCategory === 'cfsr' && currentSubsection === 'performance') {
          currentTertiary = 'county_by_county';
          setTertiaryActive(currentTertiary);
          frame.src = 'cfsr/performance/county_by_county.html';
        }
      });	  

      window.addEventListener('hashchange', navigate);
      navigate();
    })();

    // --- Auto-resize iframe to embedded report height (same-origin) ---
    (function() {
      const frame = document.getElementById('reportFrame');
      function tryResize() {
        if (!frame) return;
        try {
          const doc = frame.contentDocument || frame.contentWindow.document;
          if (!doc) return;
          const h = Math.max(
            doc.body.scrollHeight, doc.documentElement.scrollHeight,
            doc.body.offsetHeight, doc.documentElement.offsetHeight,
            doc.body.clientHeight, doc.documentElement.clientHeight
          );
          frame.style.height = h + 'px';
        } catch(e) { /* cross-origin ignore */ }
      }
      frame?.addEventListener('load', tryResize);
      setInterval(tryResize, 1000);
    })();
  </script>
</body>
</html>
